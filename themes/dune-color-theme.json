  "name": "CITS: Dune",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",

  // Palette — Dune (Villeneuve, 2021)
  // ─────────────────────────────────
  // Arrakis at dusk. The spice hangs in the air, turning everything amber.
  // Vast desert flats, cracked sietch rock, the blue-within-blue of Fremen eyes.
  // Sand. Dust. Silence.

