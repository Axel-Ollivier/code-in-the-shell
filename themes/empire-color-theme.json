{
  "name": "CITS: The Empire Codes Back",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",

  // Palette — Empire
  // ──────────────────────────────────────────────────────────────
  // Cold black steel. No warmth. No mercy.
  // The Death Star. The Executor. Order, efficiency, control.
  // Red for authority. Blue for intelligence. Amber for warning.
  // Every pixel in service of the Empire.
  //
  // bg0  = #08080f   (editor — near-black, cold blue-black)
  // bg1  = #0c0c14   (sidebar, panels)
  // bg2  = #101019   (inactive tabs, section headers)
  // bg3  = #161624   (hover states)
  // bg4  = #1e1e2e   (selection, light borders)
  // bdr  = #252538   (visible borders)
  //
  // fg0  = #e0e0ec   (cold white — function names, active text)
  // fg1  = #b8b8cc   (silver — main text)
  // fg2  = #787890   (steel gray — secondary)
  // fg3  = #3c3c58   (dim — comments)
  // fg4  = #252538   (barely visible)
  //
  // red0 = #ff2424   (bright alert red — errors)
  // red1 = #cc1111   (Imperial red — primary accent)
  // red2 = #881010   (dark red — subtle backgrounds)
  // red3 = #dd4444   (medium red — secondary accents)
  //
  // blu0 = #aaccee   (light holo blue — string escapes)
  // blu1 = #5588cc   (holo blue — types, classes)
  // blu2 = #3366aa   (deep blue)
  // blu3 = #7aadce   (scanner blue — strings)
  //
  // amb  = #cc9940   (amber — warnings, numbers)
  // ──────────────────────────────────────────────────────────────

